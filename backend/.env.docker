# Mẫu biến môi trường dành riêng cho môi trường Docker
# Copy nội dung này ra một file .env cùng thư mục với docker-compose.yml nếu muốn chạy cục bộ với Docker

# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT Authentication ───────────────────────────────────
JWT_SECRET=super_secret_jwt_key_hackathon_2026

# ─── Kết nối Cơ sở dữ liệu Quan hệ (PostgreSQL) ───────────
# LƯU Ý QUAN TRỌNG: 
# Chúng ta không dùng "localhost". Vì các container chạy chung một mạng 
# do Docker tạo ra, ta sử dụng tên service ("postgres") làm DNS (PG_HOST).
PG_HOST=postgres
PG_PORT=5432
PG_USER=brainlift
PG_PASSWORD=brainliftpassword
PG_DATABASE=brainlift

# ─── Kết nối Cơ sở dữ liệu Phi cấu trúc (MongoDB) ─────────
# Tương tự như trên, sử dụng "mongo" làm DNS name.
MONGO_URI=mongodb://mongo:27017/brainlift_ai

# ─── Tích hợp AI (OpenAI) ──────────────────────────────────
# Hãy nhập Key thật của bạn vào đây trước khi khởi chạy container
OPENAI_API_KEY=sk-your-real-openai-api-key-here
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
